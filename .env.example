# RoxyBrowser local API. Enable the API in RoxyBrowser first.
ROXYBROWSER_API_PORT=50000
ROXYBROWSER_API_TOKEN=

# Optional: direct BiDi websocket override. When set, the e2e suite skips the
# RoxyBrowser API lookup/open/create flow.
# ROXY_BIDI_WS_ENDPOINT=ws://127.0.0.1:9222

# Optional: reuse an existing BiDi session for direct or RoxyBrowser endpoints.
# ROXY_BIDI_SESSION_ID=

# Optional: choose a specific RoxyBrowser workspace/project/profile.
# ROXYBROWSER_WORKSPACE_ID=
# ROXYBROWSER_PROJECT_ID=
# ROXYBROWSER_PROFILE_ID=

# Optional: used to find or create the Firefox profile in RoxyBrowser.
# ROXYBROWSER_PROFILE_MATCH=firefox
# ROXYBROWSER_PROFILE_NAME=RoxyBrowser Firefox BiDi E2E
# ROXYBROWSER_CREATE_PROFILE_JSON={"browserType":"firefox"}
# ROXYBROWSER_DEBUG=1
# ROXYBROWSER_API_RETRIES=2

# Optional: final fallback when neither ROXY_BIDI_WS_ENDPOINT nor
# ROXYBROWSER_API_TOKEN is set.
# ROXY_BIDI_EXECUTABLE_PATH=/Applications/Firefox.app/Contents/MacOS/firefox
