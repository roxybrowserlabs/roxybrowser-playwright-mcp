{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MCP Server (stdio)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/cli.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "Debug MCP Server (HTTP :9324)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/cli.js",
      "args": ["--port", "9324"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
