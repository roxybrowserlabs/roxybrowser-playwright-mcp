{
  "name": "@roxybrowser/playwright",
  "version": "2.0.2-beta.9",
  "description": "MCP server for RoxyBrowser automation - manage browser instances and get CDP endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "roxybrowser-openapi-mcp": "./dist/bin/roxybrowser-mcp.js",
    "roxybrowser-mcp": "./dist/bin/roxybrowser-mcp.js"
  },
  "author": "RoxyBrowser",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roxybrowserlabs/roxybrowser-mcp-server.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "roxybrowser",
    "browser-automation",
    "cdp",
    "chrome-devtools-protocol"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:vendor:snapshot": "node ./scripts/generate-playwright-snapshot-source.mjs",
    "build:bundle": "pnpm build:vendor:snapshot && vite build --config vite.bundle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:bundle": "pnpm build:bundle && vitest run --config vitest.bundle.config.ts",
    "test:mcp-parity": "pnpm build:bundle && vitest run --config vitest.mcp-parity.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:bidi": "vitest run --config vitest.e2e.bidi.config.ts",
    "example:launch": "pnpm build && node ./examples/launch-local-browser.mjs",
    "example:connect-cdp": "pnpm build && node ./examples/connect-over-cdp.mjs",
    "example:connect-bidi": "pnpm build && node ./examples/connect-firefox-bidi.mjs",
    "example:probe-bidi-http": "pnpm build && node ./examples/probe-firefox-bidi-http.mjs",
    "example:launch-bidi": "pnpm build && node ./examples/launch-firefox-bidi.mjs",
    "example:page-events": "pnpm build && node ./examples/page-events-and-screenshot.mjs",
    "example:mcp-stdio": "pnpm build && node ./examples/launch-mcp-stdio.mjs",
    "mcp:stdio": "pnpm build && node ./dist/bin/roxybrowser-mcp.js",
    "mcp:http": "pnpm build && node ./dist/bin/roxybrowser-mcp.js --transport http",
    "inspector": "pnpm build && node ./node_modules/@modelcontextprotocol/inspector/client/bin/start.js -- node ./dist/bin/roxybrowser-mcp.js",
    "inspector:http": "pnpm build && node ./node_modules/@modelcontextprotocol/inspector/client/bin/start.js --transport http --server-url http://127.0.0.1:3333/mcp",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish:release": "npm run clean && npm version patch --no-git-tag-version && npm run build && npm publish",
    "publish:beta": "npm version prerelease --preid=beta --no-git-tag-version && npm run build && npm publish --tag beta"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrome-remote-interface": "^0.33.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@playwright/mcp": "0.0.76",
    "@types/chrome-remote-interface": "^0.34.0",
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "1.61.0-alpha-1781023400000",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "webdriver-bidi-protocol": "^0.4.2"
  }
}
