{
  "name": "@roxybrowser/playwright-mcp",
  "version": "0.0.8-beta.9",
  "description": "Playwright Tools for MCP",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roxybrowserlabs/roxybrowser-playwright-mcp"
  },
  "homepage": "https://playwright.dev",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Roxybrowser"
  },
  "license": "Apache-2.0",
  "scripts": {
    "start": "tsx src/cli.ts",
    "dev": "tsx --inspect src/cli.ts",
    "dev:http": "tsx --inspect src/cli.ts --port 9324",
    "build:ts": "tsc -p tsconfig.build.json && node ./scripts/prepare-build.mjs",
    "build:webpack": "npm run clean && npm run build:ts && webpack --config webpack.config.mjs && node ./scripts/prepare-dist-types.mjs",
    "build": "npm run build:webpack",
    "clean": "rimraf dist .build",
    "npm-publish": "npm run clean && npm run build && npm publish",
    "publish:release": "npm run clean && npm version patch --no-git-tag-version && npm run build && npm publish",
    "publish:beta": "npm version prerelease --preid=beta --no-git-tag-version && npm run build && npm publish --tag beta"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "package.json",
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4"
  },
  "bin": "dist/cli.mjs",
  "pnpm": {
    "patchedDependencies": {
      "playwright@1.58.2": "patches/playwright@1.58.2.patch"
    }
  }
}
